# Unreal Engine project ignore rules

# Build products and generated project files
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/

# Visual Studio files
.vs/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Visual Studio Code files
.vscode/

# Rider / JetBrains local user state
.idea/.idea.*/
.idea/**/workspace.xml
.idea/**/tasks.xml
.idea/**/usage.statistics.xml
.idea/**/dictionaries/
.idea/**/shelf/
*.DotSettings.user

# Xcode files
*.xcodeproj
*.xcworkspace

# Unreal generated files
*.code-workspace
*.modules
*.target
*.version

# Logs, crash reports, and temporary files
*.log
*.tmp
*.temp
*.pid
*.bak
*.orig
*.rej

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Packaged builds and automation output
Releases/
StagedBuilds/
Saved/StagedBuilds/
Saved/Cooked/
Saved/Crashes/
Saved/Logs/

# Local user/editor state
*.user
*.userosscache
*.sln.docstates

# Optional local-only plugin build output
Plugins/*/Binaries/
Plugins/*/Intermediate/
Plugins/*/Saved/
